# Copy to .env and fill in. Used by the local extractor (extract_steam.py).
# The Lambda gets its config from function environment variables instead
# (set in infra/lambda_setup.md), and dbt runs inside Snowflake with no env vars.

# IAM user credentials with PutObject on the raw/ prefix (see infra/aws_setup.md)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Required for real runs; not needed with --dry-run
S3_BUCKET=your-bucket-name

# Optional (defaults shown)
# AWS_REGION=us-east-1
# TOP_N=100
